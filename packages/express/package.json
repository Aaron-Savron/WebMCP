{
  "name": "@webmcp1/express",
  "version": "0.1.1",
  "description": "Express.js SDK for WebMCP - Make your Express site Agent-Ready",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webmcp1/core": "^0.1.1",
    "express": "^4.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "@types/express": "^4.17.21",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  }
}
